# ==========================================
# E-Commerce AI Platform Environment Variables
# ==========================================

# 1. Platform Infrastructure
# Used by platform-api for state and job tracking
PLATFORM_DB_URL=postgresql://admin:admin123@localhost:5432/ecommerce_platform

# Used by Celery Workers (Broker and Backend)
REDIS_URL=redis://localhost:6379

# 2. Vector Search (Qdrant)
# Used by indexer-worker and search-api
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# 3. Target Metadata Database (Postgres)
# Used by indexer-worker to save clean product data
TARGET_DB_URL=postgresql://admin:admin123@localhost:5432/ecommerce_data

# 4. Image Storage (MinIO / S3)
# Used by indexer-worker
DEST_MINIO_ENDPOINT=localhost:9000
DEST_MINIO_ACCESS_KEY=admin
DEST_MINIO_SECRET_KEY=minio123
DEST_MINIO_BUCKET=products

# 5. AI Models (LiteLLM)
# Used by indexer-worker
OPENAI_API_KEY=sk-your-openai-key
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# 6. Service Configuration
# Used by celery workers
LOG_LEVEL=INFO
CELERY_CONCURRENCY=4
